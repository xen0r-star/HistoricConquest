<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: rgba(0, 0, 0, 0.875);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.controller.overlay.PauseGameController">
    <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <VBox alignment="TOP_CENTER" StackPane.alignment="TOP_CENTER">
             <Label alignment="CENTER" style="-fx-text-fill: #FFF8ED;" styleClass="title-label" stylesheets="@../styles/style.css" text="HISTORIC" textAlignment="CENTER" textOverrun="CLIP">
                 <VBox.margin>
                     <Insets bottom="-80.0" />
                 </VBox.margin>
             </Label>
             <HBox alignment="CENTER" prefHeight="100.0" prefWidth="97.0">
                 <Circle fill="#fff4e3" radius="4.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
                 <Region maxHeight="2.0" mouseTransparent="true" prefHeight="2.0" prefWidth="400.0" style="-fx-background-color: #FFF4E3;" StackPane.alignment="CENTER">
                    </Region>
                 <Circle fill="#fff4e3" radius="4.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
             </HBox>
             <Label alignment="CENTER" styleClass="title-label" stylesheets="@../styles/style.css" text="CONQUEST" textAlignment="CENTER" textOverrun="CLIP">
                 <VBox.margin>
                     <Insets top="-50.0" />
                 </VBox.margin>
             </Label>
         <StackPane.margin>
            <Insets top="80.0" />
         </StackPane.margin>
         </VBox>
        <VBox alignment="CENTER" spacing="30.0">

            <Label text="PAUSE" textFill="#fff9e9">
                <font>
                    <Font name="System Bold" size="72.0" />
                </font>
            </Label>
            <VBox alignment="CENTER" spacing="15.0" stylesheets="@../styles/style.css">
                <Button fx:id="resumeBtn" mnemonicParsing="false" prefWidth="250.0" style="-fx-font-size: 20;" text="REPRENDRE">
               <styleClass>
                  <String fx:value="button-green" />
                  <String fx:value="button-small" />
               </styleClass></Button>
                <Button fx:id="quitMenuBtn" mnemonicParsing="false" prefWidth="250.0" style="-fx-font-size: 20;" stylesheets="@../styles/style.css" text="QUITTER">
               <styleClass>
                  <String fx:value="button-red" />
                  <String fx:value="button-small" />
               </styleClass></Button>
            </VBox>
        </VBox>

        <VBox alignment="BOTTOM_RIGHT" pickOnBounds="false" spacing="15.0" stylesheets="@../styles/style.css" StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets bottom="50.0" right="50.0" />
            </StackPane.margin>
            <Button fx:id="helpBtn" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../styles/style.css">
                <styleClass>
                    <String fx:value="button-icon" />
                    <String fx:value="button-gray" />
                </styleClass>
                <graphic>
                    <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                        <Image url="@../icons/help.png" />
                    </ImageView>
                </graphic>
                <padding>
                    <Insets bottom="0.5" left="0.5" right="0.5" top="0.5" />
                </padding>
            </Button>
            <Button fx:id="settingsBtn" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../styles/style.css">
                <styleClass>
                    <String fx:value="button-icon" />
                    <String fx:value="button-gray" />
                </styleClass>
                <graphic>
                    <ImageView fitHeight="28.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                        <Image url="@../icons/settings.png" />
                    </ImageView>
                </graphic>
                <padding>
                    <Insets bottom="0.5" left="0.5" right="0.5" top="0.5" />
                </padding>
            </Button>
        </VBox>
    </StackPane>
</AnchorPane>
