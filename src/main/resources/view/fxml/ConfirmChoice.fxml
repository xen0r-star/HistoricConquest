<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: rgba(0, 0, 0, 0);" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.controller.overlay.ConfirmChoiceController">
    <VBox alignment="CENTER" maxHeight="125.0" maxWidth="350.0" minHeight="125.0" minWidth="350.0" prefHeight="125.0" prefWidth="350.0" spacing="20.0" style="-fx-padding: 20; -fx-background-radius: 10; -fx-border-radius: 7; -fx-border-width: 3; -fx-border-insets: 0;">
        <Label fx:id="messageLabel" style="-fx-font-size: 20px; -fx-text-fill: #ffffff;" text="Voulez-vous continuer ?" textAlignment="CENTER" wrapText="true">
          <font>
             <Font size="32.0" />
          </font></Label>
        <HBox alignment="CENTER" spacing="15.0">
            <Button fx:id="btn1" mnemonicParsing="false" onAction="#handleBtn1" text="Valider">
             <styleClass>
                <String fx:value="button-beige" />
                <String fx:value="button-small" />
             </styleClass></Button>
            <Button fx:id="btn2" mnemonicParsing="false" onAction="#handleBtn2" prefHeight="35.0" text="Annuler">
             <styleClass>
                <String fx:value="button-beige" />
                <String fx:value="button-small" />
             </styleClass></Button>
        </HBox>
       <styleClass>
          <String fx:value="button-gray" />
          <String fx:value="button-small" />
          <String fx:value="not-hover" />
       </styleClass>
    </VBox>
</StackPane>
