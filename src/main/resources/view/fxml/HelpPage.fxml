<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="551.0" prefWidth="357.0" style="-fx-background-radius: 10; -fx-border-width: 0;" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.controller.overlay.HelpController">
   <Button alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#closeFromUi" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #00000000;" textAlignment="CENTER" textFill="#070707" StackPane.alignment="TOP_RIGHT">
