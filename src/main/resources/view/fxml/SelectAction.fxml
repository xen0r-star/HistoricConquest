<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane  maxHeight="212.0" maxWidth="590.0" minHeight="212.0" minWidth="590.0" prefHeight="212.0" prefWidth="590.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.controller.page.SelectAction">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <styleClass>
      <String fx:value="button-blue" />
      <String fx:value="button-main" />
      <String fx:value="not-hover" />
   </styleClass>
   <children>
      <Label layoutX="115.0" layoutY="25.0" text="SELECT YOUR ACTION" textFill="#eedcbe">
         <font>
            <Font name="Georgia Bold" size="32.0" />
         </font>
      </Label>

      <Button fx:id="buttonAttack" onAction="#startAttack" layoutX="30.0" layoutY="100.0" text="Attack Zone" prefHeight="54.0" prefWidth="170.0">
         <styleClass>
            <String fx:value="button-red" />
            <String fx:value="button-small" />
         </styleClass>
      </Button>


      <Button fx:id="buttonTravel" onAction="#startTravel" layoutX="210.0" layoutY="100.0" text="Travel" prefHeight="54.0" prefWidth="170.0">
         <styleClass>
            <String fx:value="button-beige" />
            <String fx:value="button-small" />
         </styleClass>
      </Button>

      <Button fx:id="buttonPower" onAction="#startPower" layoutX="390.0" layoutY="100.0" text="Power Up" prefHeight="54.0" prefWidth="170.0">
         <styleClass>
            <String fx:value="button-green" />
            <String fx:value="button-small" />
         </styleClass>
      </Button>

   </children>
</AnchorPane>
