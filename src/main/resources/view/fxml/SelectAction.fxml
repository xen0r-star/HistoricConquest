<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="root2" maxHeight="212.0" maxWidth="590.0" minHeight="212.0" minWidth="590.0" prefHeight="212.0" prefWidth="590.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.controller.page.SelectAction">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
   <styleClass>
      <String fx:value="button-blue" />
      <String fx:value="button-main" />
      <String fx:value="not-hover" />
   </styleClass>
   <children>
      <Label layoutX="115.0" layoutY="25.0" text="SELECT YOUR ACTION" textFill="#eedcbe">
         <font>
            <Font name="Georgia Bold" size="32.0" />
         </font>
      </Label>

      <Button fx:id="buttonAttack" layoutX="30.0" layoutY="100.0" onAction="#startAttack" prefHeight="54.0" prefWidth="170.0" text="Attack Zone">
         <styleClass>
            <String fx:value="button-red" />
            <String fx:value="button-small" />
         </styleClass>
      </Button>

      <Button fx:id="buttonTravel" layoutX="210.0" layoutY="100.0" onAction="#startTravel" prefHeight="54.0" prefWidth="170.0" text="Travel">
         <styleClass>
            <String fx:value="button-beige" />
            <String fx:value="button-small" />
         </styleClass>
      </Button>

      <Button fx:id="buttonPower" layoutX="390.0" layoutY="100.0" onAction="#startPower" prefHeight="54.0" prefWidth="170.0" text="Power Up">
         <styleClass>
            <String fx:value="button-green" />
            <String fx:value="button-small" />
         </styleClass>
      </Button>

      <HBox alignment="CENTER" layoutY="170.0" prefWidth="590.0" AnchorPane.bottomAnchor="2.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>
            <Button fx:id="btnClose" onAction="#closeAlliance" style="-fx-background-color: transparent; -fx-text-fill: #EEDCBE; -fx-cursor: hand;-fx-padding: 0;" text="CLOSE" underline="true">
               <font>
                  <Font name="Georgia" size="14.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</AnchorPane>