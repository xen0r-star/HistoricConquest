<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: rgba(0, 0, 0, 0.875);" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.controller.overlay.SettingsController">
    <StackPane maxHeight="650.0" maxWidth="700.0" minHeight="650.0" minWidth="700.0" prefHeight="650.0" prefWidth="700.0" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-width: 4; -fx-border-insets: 0;">
        <VBox alignment="CENTER" maxHeight="600" maxWidth="750">
            <HBox alignment="CENTER" spacing="10.0">
                <ImageView fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../icons/settings.png" />
                </ImageView>
                <Label text="SETTINGS" textFill="WHITE">
                <font>
                   <Font name="Georgia Bold" size="36.0" />
                </font></Label>
            </HBox>
            <VBox prefHeight="405.0" prefWidth="631.0" spacing="40.0">
                <padding>
                    <Insets bottom="30" left="40" right="40" top="30" />
                </padding>
                <VBox prefWidth="100.0" spacing="5.0">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="AUDIO" textFill="WHITE" />
                    </HBox>
                    <GridPane hgap="20" prefWidth="557.0" style="-fx-background-color: #00000030; -fx-background-radius: 10;" vgap="18">
                        <Label minWidth="-Infinity" text="Music" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <Slider fx:id="musicSlider" prefWidth="320" value="50.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label fx:id="musicValueLabel" alignment="CENTER_RIGHT" contentDisplay="RIGHT" minWidth="-Infinity" prefHeight="24.0" prefWidth="62.0" text="50%" textFill="WHITE" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <Label minWidth="-Infinity" text="Silent" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <CheckBox fx:id="muteCheck" style="-fx-background-color: #ffffff; -fx-border-width: 0;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <columnConstraints>
                            <ColumnConstraints />
                            <ColumnConstraints maxWidth="307.0" minWidth="267.0" prefWidth="267.0" />
                            <ColumnConstraints maxWidth="83.5" minWidth="50.5" prefWidth="58.5" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>
                        <padding>
                            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                        </padding>
                    </GridPane>
                </VBox>
                <VBox prefHeight="200.0" prefWidth="100.0" spacing="5.0">
                    <Label text="DISPLAY" textFill="WHITE" />
                    <GridPane hgap="20" style="-fx-background-color: #00000030; -fx-background-radius: 10;" vgap="18">
                        <Label minWidth="-Infinity" text="Resolution" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <ComboBox fx:id="resolutionCombo" prefWidth="200" style="-fx-background-color: #ffffff;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label minWidth="-Infinity" text="Full screen" textFill="WHITE" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <CheckBox fx:id="fullscreenCheck" style="-fx-background-color: #ffffff;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <columnConstraints>
                            <ColumnConstraints />
                            <ColumnConstraints />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints />
                            <RowConstraints />
                            <RowConstraints />
                        </rowConstraints>
                        <padding>
                            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                        </padding>
                    </GridPane>
                </VBox>
            </VBox>
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <padding>
                    <Insets bottom="20" left="30" right="30" top="15" />
                </padding>
                <Button onAction="#onCancel" text="CANCEL">
                    <styleClass>
                        <String fx:value="button-small" />
                        <String fx:value="button-red" />
                    </styleClass></Button>
                <Button onAction="#onSave" text="SAVE">
                    <styleClass>
                        <String fx:value="button-small" />
                        <String fx:value="button-beige" />
                    </styleClass></Button>
            </HBox>
        </VBox>
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
        </padding>
        <styleClass>
            <String fx:value="button-gray" />
            <String fx:value="button-small" />
            <String fx:value="not-hover" />
        </styleClass>
    </StackPane>
</StackPane>
