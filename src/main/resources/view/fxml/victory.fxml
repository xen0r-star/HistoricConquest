<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="root" prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: rgba(0,0,0,0.85);" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/21.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.controller.game.endGame">

    <children>
        <VBox alignment="CENTER" maxHeight="450.0" maxWidth="600.0" spacing="30.0" style="-fx-background-color: #F7E7CE; -fx-border-color: #907f66; -fx-border-width: 6;" styleClass="HUD-border">
            <children>

                <VBox alignment="CENTER" minHeight="100.0" prefHeight="100.0" style="-fx-background-color: #6B1515;" VBox.vgrow="NEVER">
                    <children>
                        <Label text="VICTORY" textFill="#EEDCBE">
                            <font>
                                <Font name="Georgia Bold" size="56.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label text="THE CONQUEROR IS:" textFill="#6B1515">
                            <font>
                                <Font name="Georgia Bold" size="24.0" />
                            </font>
                        </Label>

                        <Label fx:id="lblWinnerName" text="PLAYER 1 &amp; PLAYER 2" textAlignment="CENTER" textFill="#333333" wrapText="true">
                            <font>
                                <Font name="Georgia Bold" size="25.0" />
                            </font>
                        </Label>
                    </children>
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                </VBox>

            </children>
            <padding>
                <Insets bottom="40.0" />
            </padding>
        </VBox>
    </children>
</StackPane>