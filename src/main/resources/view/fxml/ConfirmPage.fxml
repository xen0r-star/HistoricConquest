<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
           minWidth="-Infinity" prefHeight="370.0" prefWidth="416.0" stylesheets="@../styles/style.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.historicconquest.historicconquest.view.QuestionPage">
   <styleClass>
      <String fx:value="button-blue"/>
      <String fx:value="HUD-border"/>
   </styleClass>
   <Label style="-fx-text-fill: #000000; -fx-underline-width: 3px;" text="PAY ATTENTION"
          StackPane.alignment="TOP_CENTER">
      <font>
         <Font name="Georgia Bold" size="23.0"/>
      </font>
      <StackPane.margin>
         <Insets top="25.0"/>
      </StackPane.margin>
   </Label>
   <HBox maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="64.0" prefWidth="254.0"
         StackPane.alignment="BOTTOM_CENTER">
      <Button fx:id="yesButton" mnemonicParsing="false" onAction="#destroyStackPane" prefHeight="50.0"
              prefWidth="110.0"
              style="-fx-border-color: green; -fx-border-width: 2px; -fx-border-radius: 5px; -fx-background-color: green;"
              text="Yes, I am">
         <font>
            <Font name="Georgia Bold" size="18.0"/>
         </font>
         <HBox.margin>
            <Insets right="25.0"/>
         </HBox.margin>
      </Button>
      <Button fx:id="noButton" mnemonicParsing="false" onAction="#hideConfirm" prefHeight="50.0" prefWidth="120.0"
              style="-fx-background-color: #D10020;" text="No, I don't">
         <font>
            <Font name="Georgia Bold" size="18.0"/>
         </font>
      </Button>
   </HBox>
   <Label text="Are you sure about your difficult level ?" StackPane.alignment="TOP_LEFT">
      <StackPane.margin>
         <Insets left="25.0" top="100.0"/>
      </StackPane.margin>
      <font>
         <Font name="Georgia Regular" size="20.0"/>
      </font>
   </Label>
   <ImageView fitHeight="85.0" fitWidth="173.0" pickOnBounds="true" preserveRatio="true">
      <StackPane.margin>
         <Insets top="30.0"/>
      </StackPane.margin>
      <Image url="@../icons/alert.png"/>
   </ImageView>
</StackPane>
