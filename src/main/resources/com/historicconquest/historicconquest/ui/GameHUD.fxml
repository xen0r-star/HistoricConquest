<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.ui.GameHUD">
   <Region mouseTransparent="true" nodeOrientation="LEFT_TO_RIGHT" prefHeight="200.0" prefWidth="200.0" styleClass="map-grid" stylesheets="@../styles/style.css">
      <StackPane.margin>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </StackPane.margin>
   </Region>
   <Pane fx:id="mapViewport" prefHeight="200.0" prefWidth="200.0" style="-fx-border-color: transparent;">
      <StackPane.margin>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </StackPane.margin>
   </Pane>
   <Region fx:id="border" mouseTransparent="true" prefHeight="400.0" prefWidth="290.0" style="-fx-border-style: solid, segments(15, 15) line-join miter, solid;" styleClass="HUD-border" StackPane.alignment="CENTER">
      <StackPane.margin>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </StackPane.margin>
   </Region>
   <StackPane mouseTransparent="true" prefHeight="150.0" prefWidth="200.0" StackPane.alignment="CENTER">
      <StackPane.margin>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </StackPane.margin>
   </StackPane>
</StackPane>
