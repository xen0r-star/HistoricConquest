<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="root" prefHeight="1080.0" prefWidth="1920.0" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.ui.MultiplayerPage">
   <Pane prefHeight="200.0" prefWidth="200.0" style="-fx-border-color: #907f66; -fx-border-width: 2;">
      <StackPane.margin>
         <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
      </StackPane.margin>
   </Pane>
   <Region mouseTransparent="true" nodeOrientation="LEFT_TO_RIGHT" prefHeight="200.0" prefWidth="200.0" styleClass="map-grid-transparent" stylesheets="@../styles/style.css">
      <StackPane.margin>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </StackPane.margin>
   </Region>
   <Pane fx:id="mapViewport" prefHeight="200.0" prefWidth="200.0" style="-fx-border-color: transparent;">
      <StackPane.margin>
         <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
      </StackPane.margin>
   </Pane>
   <Region mouseTransparent="true" prefHeight="400.0" prefWidth="290.0" styleClass="HUD-border" StackPane.alignment="CENTER">
      <StackPane.margin>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </StackPane.margin>
   </Region>
   <VBox alignment="TOP_CENTER">
      <Label alignment="CENTER" style="-fx-text-fill: #FFF8ED;" styleClass="title-label" stylesheets="@../styles/style.css" text="HISTORIC" textAlignment="CENTER" textOverrun="CLIP">
         <VBox.margin>
            <Insets bottom="-80.0" />
         </VBox.margin>
      </Label>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="97.0">
         <Circle fill="#fff4e3" radius="4.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
         <Region maxHeight="2.0" mouseTransparent="true" prefHeight="2.0" prefWidth="400.0" style="-fx-background-color: #FFF4E3;" StackPane.alignment="CENTER">
            </Region>
         <Circle fill="#fff4e3" radius="4.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      </HBox>
      <Label alignment="CENTER" styleClass="title-label" stylesheets="@../styles/style.css" text="CONQUEST" textAlignment="CENTER" textOverrun="CLIP">
         <VBox.margin>
            <Insets top="-50.0" />
         </VBox.margin>
      </Label>
      <StackPane.margin>
         <Insets bottom="100.0" left="100.0" right="100.0" top="100.0" />
      </StackPane.margin>
   </VBox>
   <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
      <StackPane.margin>
         <Insets bottom="50.0" left="50.0" right="50.0" top="300.0" />
      </StackPane.margin>
      <padding>
         <Insets top="25.0" />
      </padding>
      <Pane fx:id="JoinBtn" maxHeight="350.0" maxWidth="300.0" prefHeight="350.0" prefWidth="300.0" style="-fx-border-width: 2, 2; -fx-border-insets: 6, 11; -fx-border-style: solid, solid; -fx-cursor: hand; -fx-background-radius: 3; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);" styleClass="button-blue">
         <ImageView fitHeight="100.0" fitWidth="100.0" layoutX="100.0" layoutY="29.0" pickOnBounds="true" preserveRatio="true">
            <Image url="@../images/globe-outline.png" />
         </ImageView>
         <Label alignment="CENTER" layoutX="34.0" layoutY="129.0" prefHeight="34.0" prefWidth="232.0" text="JOIN GAME" textFill="#eedcbe">
            <font>
               <Font name="Georgia Bold" size="30.0" />
            </font>
         </Label>
         <Label alignment="TOP_LEFT" contentDisplay="TOP" layoutX="34.0" layoutY="192.0" lineSpacing="3.0" prefHeight="131.0" prefWidth="232.0" text="Enter a game code to join a match hosted by another player. Ask the host for the code and jump straight into the game." textAlignment="CENTER" textFill="#eedcbe" textOverrun="CLIP" wrapText="true">
            <font>
               <Font name="Georgia Bold" size="14.0" />
            </font>
         </Label>
      </Pane>
      <Pane fx:id="HostBtn" maxHeight="350.0" maxWidth="300.0" prefHeight="350.0" prefWidth="300.0" style="-fx-border-width: 2, 2; -fx-border-insets: 6, 11; -fx-border-style: solid, solid; -fx-cursor: hand; -fx-background-radius: 3; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);" styleClass="button-green">
         <ImageView fitHeight="100.0" fitWidth="100.0" layoutX="100.0" layoutY="29.0" pickOnBounds="true" preserveRatio="true">
            <Image url="@../images/flash.png" />
         </ImageView>
         <Label alignment="CENTER" layoutX="34.0" layoutY="129.0" prefHeight="34.0" prefWidth="232.0" text="HOST GAME" textFill="#eedcbe">
            <font>
               <Font name="Georgia Bold" size="30.0" />
            </font>
         </Label>
         <Label alignment="TOP_LEFT" contentDisplay="TOP" layoutX="34.0" layoutY="192.0" lineSpacing="3.0" prefHeight="131.0" prefWidth="232.0" text="Enter a game code to join a match hosted by another player. Ask the host for the code and jump straight into the game." textAlignment="CENTER" textFill="#eedcbe" textOverrun="CLIP" wrapText="true">
            <font>
               <Font name="Georgia Bold" size="14.0" />
            </font>
         </Label>
      </Pane>
   </HBox>
   <Button fx:id="BackBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" text="Back" StackPane.alignment="TOP_LEFT">
      <StackPane.margin>
         <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
      </StackPane.margin>
      <styleClass>
         <String fx:value="button-small" />
         <String fx:value="button-red" />
      </styleClass>
      <graphic>
         <ImageView fitHeight="24.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
            <Image url="@../images/caret-back-outline.png" />
         </ImageView>
      </graphic>
      <padding>
         <Insets bottom="5.0" left="5.0" right="10.0" top="5.0" />
      </padding>
   </Button>
</StackPane>
