<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.historicconquest.historicconquest.ui.PageSettingsController">

    <!-- PANNEAU PRINCIPAL -->
    <VBox alignment="CENTER" maxHeight="600" maxWidth="750" spacing="0" styleClass="settings-panel">

        <!-- TITRE DU PANNEAU -->
        <HBox alignment="CENTER_LEFT" styleClass="settings-header">
            <Label styleClass="settings-title" text="PARAMÈTRES" />
        </HBox>

        <!-- CONTENU SCROLLABLE -->
        <VBox spacing="25" styleClass="settings-content">
            <padding>
                <Insets bottom="30" left="40" right="40" top="30" />
            </padding>

            <!-- SECTION : AUDIO -->
            <Label styleClass="settings-section-title" text="— AUDIO" />

            <GridPane hgap="20" styleClass="settings-grid" vgap="18">
                <!-- Musique -->
                <Label styleClass="settings-label" text="Musique" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Slider fx:id="musicSlider" max="100" min="0" prefWidth="320" styleClass="settings-slider" value="80" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Label fx:id="musicValueLabel" styleClass="settings-value" text="80%" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                <!-- Effets sonores -->
                <Label styleClass="settings-label" text="Effets sonores" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Slider fx:id="sfxSlider" max="100" min="0" prefWidth="320" styleClass="settings-slider" value="70" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Label fx:id="sfxValueLabel" styleClass="settings-value" text="70%" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                <!-- Muet -->
                <Label styleClass="settings-label" text="Muet" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <CheckBox fx:id="muteCheck" styleClass="settings-checkbox" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <!-- SÉPARATEUR -->
            <HBox styleClass="settings-separator" />

            <!-- SECTION : AFFICHAGE -->
            <Label styleClass="settings-section-title" text="— AFFICHAGE" />

            <GridPane hgap="20" styleClass="settings-grid" vgap="18">
                <!-- Résolution -->
                <Label styleClass="settings-label" text="Résolution" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="resolutionCombo" prefWidth="200" styleClass="settings-combo" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- Plein écran -->
                <Label styleClass="settings-label" text="Plein écran" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <CheckBox fx:id="fullscreenCheck" styleClass="settings-checkbox" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Langue -->
                <Label styleClass="settings-label" text="Langue" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <ComboBox fx:id="langCombo" prefWidth="200" styleClass="settings-combo" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

        </VBox>

        <!-- BOUTONS BAS -->
        <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="settings-footer">
            <padding>
                <Insets bottom="20" left="30" right="30" top="15" />
            </padding>
            <Button fx:id="cancelBtn" onAction="#onCancel" styleClass="settings-btn-cancel" text="ANNULER" />
            <Button fx:id="saveBtn" onAction="#onSave" styleClass="settings-btn-save" text="SAUVEGARDER" />
        </HBox>

    </VBox>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>

</StackPane>
